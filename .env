TELEGRAM_BOT_TOKEN="put your telegram bot token here "
OLLAMA_URL=http://localhost:11434    # put your own llama model running port if that is different 
OLLAMA_MODEL=llama3

# ─────────────────────────────────────────────
# RAG Tuning (optional — defaults shown)
